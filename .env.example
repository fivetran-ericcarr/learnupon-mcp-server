# LearnUpon MCP Server — credentials
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

LU_SUBDOMAIN=your_subdomain_here
LU_API_KEY=your_api_key_here
LU_API_SECRET=your_api_secret_here

# API credentials are in LearnUpon admin:
# Settings → Integrations → API
#
# LU_SUBDOMAIN is the part before .learnupon.com in your admin URL
# e.g. for https://acmepartners.learnupon.com → LU_SUBDOMAIN=acmepartners
